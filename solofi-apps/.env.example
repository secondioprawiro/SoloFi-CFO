# OKX.AI
OKX_AI_API_KEY=your_okx_ai_api_key_here
OKX_AI_AGENT_ID=your_agent_id_here

# LLM — Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Database — Supabase new API key system (sb_publishable_/sb_secret_, replaces anon/service_role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
SUPABASE_SECRET_KEY=sb_secret_your_key_here

# Web3 — X Layer Testnet (chain 1952; use mainnet rpc.xlayer.tech + chain 196 for production)
X_LAYER_RPC_URL=https://testrpc.xlayer.tech
X_LAYER_CHAIN_ID=1952
AGENT_WALLET_PRIVATE_KEY=your_agent_wallet_private_key_here

# Token Addresses (X Layer)
USDC_ADDRESS=0x...
USDT_ADDRESS=0x...

# OKX Payment SDK (x402) — from the OKX Developer Portal (web3.okx.com/onchainos/dev-portal).
# NOT the same credential as OKX_AI_API_KEY/OKX_AI_AGENT_ID above (that's ASP marketplace identity;
# this is the general Web3 API key used to sign/settle x402 payments). Leave blank to run /mcp for free.
OKX_API_KEY=your_okx_developer_portal_api_key_here
OKX_SECRET_KEY=your_okx_developer_portal_secret_key_here
OKX_PASSPHRASE=your_okx_developer_portal_passphrase_here
X402_PRICE=$0.20
X402_PAY_TO_ADDRESS=

# App
PORT=3000
NODE_ENV=development
